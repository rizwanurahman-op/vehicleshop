PORT=5000
MONGODB_URI=mongodb://localhost:27017/vehiclebook

# ─── JWT Secrets ────────────────────────────────────────────────────────────────
# Generate strong secrets using: node -e "require('crypto').randomBytes(48).toString('hex')|xargs echo"
# Must be at LEAST 32 characters. Using 96-hex-char (48 bytes of entropy) is recommended.
JWT_ACCESS_SECRET=GENERATE_STRONG_SECRET_MIN_32_CHARS_USE_node_crypto_randomBytes_48
JWT_REFRESH_SECRET=GENERATE_DIFFERENT_STRONG_SECRET_MIN_32_CHARS

JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
CORS_ORIGIN=http://localhost:3000
NODE_ENV=development

# --- Email (Nodemailer) ---
# Gmail: enable 2FA → Google Account → Security → App Passwords → generate 16-char password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_16char_app_password
EMAIL_FROM=VehicleBook <your_gmail@gmail.com>

# Frontend URL (used in password reset email links)
CLIENT_URL=http://localhost:3000

# ─── Google Drive Backup (optional) ─────────────────────────────────────────────
# Step 1: Google Cloud Console → Enable Google Drive API
# Step 2: IAM & Admin → Service Accounts → Create → Download JSON key
# Step 3: Google Drive → Create folder → Share with service account email (Editor)
# Step 4: Copy folder ID from Drive URL: drive.google.com/drive/folders/<FOLDER_ID>
#
# The private key comes from the downloaded JSON file ("private_key" field).
# Paste it as-is (with the -----BEGIN/END----- lines) — newlines are stored as \n
GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id_here
GOOGLE_SERVICE_ACCOUNT_EMAIL=vehiclebook-backup@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEo...\n-----END RSA PRIVATE KEY-----\n"
